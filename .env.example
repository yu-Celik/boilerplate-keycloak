# ═══════════════════════════════════════════════════
# Boilerplate Keycloak + Next.js
# Copy this file: cp .env.example .env
# ═══════════════════════════════════════════════════

# ── Keycloak Image ─────────────────────────────────
# Pin to a specific nightly tag if latest breaks (e.g., nightly-2026-03-30)
KC_IMAGE_TAG=nightly

# ── Keycloak Admin ─────────────────────────────────
KC_ADMIN_USERNAME=admin
KC_ADMIN_PASSWORD=admin

# ── Keycloak Hostname ──────────────────────────────
KC_HOSTNAME=http://localhost:3991

# ── Database ───────────────────────────────────────
KC_DB_NAME=keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=change_me

# ── Next.js Auth ───────────────────────────────────
NEXTAUTH_URL=http://localhost:3990
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# ── Keycloak OIDC (App Client) ─────────────────────
KC_ISSUER=http://localhost:3991/realms/boilerplate
KC_ISSUER_INTERNAL=http://keycloak:8080/realms/boilerplate
KC_CLIENT_ID=boilerplate-app
KC_CLIENT_SECRET=

# ── Keycloak Service Account ───────────────────────
KC_SERVICE_ACCOUNT_CLIENT_ID=boilerplate-service
KC_SERVICE_ACCOUNT_CLIENT_SECRET=

# ═══════════════════════════════════════════════════
# FEATURES KEYCLOAK (décommente pour activer)
# ═══════════════════════════════════════════════════

# Authentification sans mot de passe (Passkeys/WebAuthn)
# KC_FEATURE_PASSKEYS=enabled

# Protection anti-vol de token (DPoP)
# KC_FEATURE_DPOP=enabled

# Échange de tokens entre microservices (RFC 8693)
# KC_FEATURE_TOKEN_EXCHANGE_STANDARD=enabled

# Forcer 2FA pour des actions critiques (Step-up)
# KC_FEATURE_STEP_UP_AUTHENTICATION=enabled

# Codes de secours si perte OTP
# KC_FEATURE_RECOVERY_CODES=enabled

# Policies d'auth en JavaScript
# KC_FEATURE_SCRIPTS=enabled
